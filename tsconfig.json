{
    "compilerOptions": {
        "module": "commonjs",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2021",
        "sourceMap": true,
        "outDir": "./dist",
        "ignoreDeprecations": "6.0",
        "baseUrl": "./",
        "incremental": true,
        "strict": true,
        "skipLibCheck": true,
        "strictPropertyInitialization": false
    },
    "include": [
        "src/**/*.ts",
        "prisma/**/*.ts"
    ]
}