generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoVeiculo {
  PROPRIO
  LOCADO
}

enum TipoVinculoMotorista {
  EFETIVO
  CONTRATADO
  COMISSIONADO
}

enum TipoParticipacao {
  PACIENTE
  ACOMPANHANTE
}

enum RoleUsuario {
  ADMIN
  OPERADOR
}

model Usuario {
  id        Int         @id @default(autoincrement()) @map("id_usuario")
  nome      String      @db.VarChar(160)
  email     String      @unique @db.VarChar(160)
  senhaHash String      @map("senha_hash") @db.VarChar(180)
  role      RoleUsuario @default(OPERADOR)
  ativo     Boolean     @default(true)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("usuarios")
}

model Veiculo {
  id        Int         @id @default(autoincrement()) @map("id_veiculo")
  nome      String      @db.VarChar(120)
  placa     String      @unique @db.VarChar(10)
  ano       Int
  renavam   String      @unique @db.VarChar(20)
  tipo      TipoVeiculo @map("tipo_veiculo")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  viagens   Viagem[]

  @@map("veiculos")
}

model Motorista {
  id                    Int                  @id @default(autoincrement()) @map("id_motorista")
  nome                  String               @db.VarChar(160)
  cpf                   String               @unique @db.VarChar(14)
  endereco              String               @db.VarChar(255)
  renach                String               @unique @db.VarChar(30)
  validadeHabilitacao   DateTime             @map("validade_habilitacao") @db.Date
  tipoHabilitacao       String               @map("tipo_habilitacao") @db.VarChar(5)
  tipoVinculo           TipoVinculoMotorista @map("tipo_vinculo")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  viagens               Viagem[]

  @@map("motoristas")
}

model Cidade {
  id              Int      @id @default(autoincrement()) @map("id_cidade")
  nome            String   @db.VarChar(120)
  uf              String   @db.Char(2)
  viagensOrigem   Viagem[] @relation("CidadeOrigem")
  viagensDestino  Viagem[] @relation("CidadeDestino")

  @@unique([nome, uf])
  @@map("cidades")
}

model Pessoa {
  id             Int            @id @default(autoincrement()) @map("id_pessoa")
  nome           String         @db.VarChar(160)
  cpf            String?        @unique @db.VarChar(14)
  cartaoSus      String?        @unique @map("cartao_sus") @db.VarChar(20)
  dataNascimento DateTime?      @map("data_nascimento") @db.Date
  telefone       String?        @db.VarChar(20)
  endereco       String?        @db.VarChar(255)
  municipio      String?        @db.VarChar(120)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  participacoes  ViagemPessoa[]

  @@map("pessoas")
}

model Viagem {
  id              Int            @id @default(autoincrement()) @map("id_viagem")
  veiculoId       Int            @map("id_veiculo")
  motoristaId     Int            @map("id_motorista")
  cidadeOrigemId  Int            @map("id_cidade_origem")
  cidadeDestinoId Int            @map("id_cidade_destino")
  dataSaida       DateTime       @map("data_saida")
  dataEntrada     DateTime?      @map("data_entrada")
  observacao      String?        @db.Text
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  veiculo         Veiculo        @relation(fields: [veiculoId], references: [id], onDelete: Restrict)
  motorista       Motorista      @relation(fields: [motoristaId], references: [id], onDelete: Restrict)
  cidadeOrigem    Cidade         @relation("CidadeOrigem", fields: [cidadeOrigemId], references: [id], onDelete: Restrict)
  cidadeDestino   Cidade         @relation("CidadeDestino", fields: [cidadeDestinoId], references: [id], onDelete: Restrict)
  pessoas         ViagemPessoa[]

  @@index([dataSaida])
  @@index([motoristaId, dataSaida])
  @@index([veiculoId, dataSaida])
  @@map("viagens")
}

model ViagemPessoa {
  id                Int              @id @default(autoincrement()) @map("id_viagem_pessoa")
  viagemId          Int              @map("id_viagem")
  pessoaId          Int              @map("id_pessoa")
  tipoParticipacao  TipoParticipacao @map("tipo_participacao")
  observacao         String?          @db.Text

  viagem            Viagem           @relation(fields: [viagemId], references: [id], onDelete: Cascade)
  pessoa            Pessoa           @relation(fields: [pessoaId], references: [id], onDelete: Restrict)

  @@unique([viagemId, pessoaId, tipoParticipacao])
  @@index([pessoaId])
  @@map("viagens_pessoas")
}
